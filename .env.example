# ChangeTrail — environment config
# Copyright (c) 2026 cvemula1 — MIT License
# https://github.com/cvemula1/ChangeTrail
#
# Copy this file to .env and fill in what you need.

# General
CT_DEBUG=false

# Database (PostgreSQL)
CT_DATABASE_URL=postgresql+asyncpg://changetrail:changetrail@localhost:5432/changetrail
CT_DATABASE_URL_SYNC=postgresql+psycopg2://changetrail:changetrail@localhost:5432/changetrail

# API
CT_API_HOST=0.0.0.0
CT_API_PORT=8000
CT_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Kubernetes Collector
CT_KUBERNETES_ENABLED=true
CT_KUBERNETES_NAMESPACE=        # empty = all namespaces
CT_KUBERNETES_POLL_INTERVAL=30  # seconds

# GitHub Collector
CT_GITHUB_ENABLED=false
CT_GITHUB_TOKEN=                # Personal access token or GitHub App token
CT_GITHUB_WEBHOOK_SECRET=       # Webhook secret for signature verification
CT_GITHUB_REPOS=[]              # e.g. ["org/repo1","org/repo2"]

# AWS Collector (planned)
CT_AWS_ENABLED=false
CT_AWS_REGION=us-east-1

# Slack Integration
CT_SLACK_SIGNING_SECRET=       # Slack App signing secret
CT_SLACK_BOT_TOKEN=            # Bot token (xoxb-...)
CT_SLACK_WEBHOOK_URL=          # Incoming webhook for alert notifications

# Retention
CT_EVENT_RETENTION_DAYS=30
